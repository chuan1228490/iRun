# ==========================================
# 小i跑腿 — Docker 环境变量
# ==========================================
# 复制此文件为 .env 并按需修改
#   cp .env.example .env
# ==========================================

# MySQL root 密码（首次初始化后修改无效）
MYSQL_ROOT_PASSWORD=root123

# 宿主机端口映射（避免与本地服务冲突）
MYSQL_PORT=3308
REDIS_PORT=6381
BACKEND_PORT=8080

# JWT 签名密钥（生产环境务必修改为强随机字符串，长度 ≥ 32）
JWT_ADMIN_SECRET=docker-admin-secret-key-min-32chars!
JWT_USER_SECRET=docker-user-secret-key-min-32chars!!

# ---- 外部服务（Docker 本地测试可留空） ----
# 阿里云 AccessKey（OSS + SMS）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# 微信小程序
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 腾讯地图
TENCENT_MAP_API_KEY=
